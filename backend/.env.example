# ═══════════════════════════════════════════════════════════
# EduNation Backend — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

PORT=5000

# ── Supabase ──
# Create a free project at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Upstash Redis (optional, but recommended for caching) ──
# Create a free database at https://console.upstash.com
REDIS_URL=https://your-redis-instance.upstash.io
REDIS_TOKEN=your_redis_token_here
